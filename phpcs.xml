<?xml version="1.0"?>
<ruleset name="BeepBeep AI Plugin Check">
	<description>WordPress Plugin Check ruleset for beepbeep-ai-alt-text-generator</description>

	<!-- Scan only plugin PHP files -->
	<file>.</file>
	<arg name="extensions" value="php"/>

	<!-- Exclude non-plugin directories -->
	<exclude-pattern>vendor/*</exclude-pattern>
	<exclude-pattern>node_modules/*</exclude-pattern>
	<exclude-pattern>tests/*</exclude-pattern>
	<exclude-pattern>.wporg-svn/*</exclude-pattern>
	<exclude-pattern>output/*</exclude-pattern>

	<!-- WordPress Extra (Plugin Check uses this) -->
	<rule ref="WordPress-Extra"/>

	<!-- Minimum PHP version -->
	<config name="minimum_supported_wp_version" value="6.2"/>
	<config name="testVersion" value="7.4-"/>

	<!-- Show sniff codes -->
	<arg value="s"/>
	<arg name="colors"/>
</ruleset>
