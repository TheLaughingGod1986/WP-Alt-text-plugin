# Copy to .env and export, or pass inline:
#   BBAI_E2E_BASE_URL=http://127.0.0.1:8888 BBAI_E2E_STORAGE_STATE=./storageState.json npm test

BBAI_E2E_BASE_URL=http://127.0.0.1:8888
# Optional: path to Playwright storage state after logging into wp-admin
# BBAI_E2E_STORAGE_STATE=./storageState.json

# Connected entitlement exhaustion suite (destructive: consumes one prepared backend credit).
# Link this wp-env site to a dedicated test backend account with exactly 1 remaining credit.
# BBAI_E2E_ADMIN_USER=admin
# BBAI_E2E_ADMIN_PASS=password
# BBAI_E2E_CONNECTED_ENTITLEMENT=1
# BBAI_E2E_RUN_CONNECTED_GENERATION=1
# Optional aliases accepted by the connected suite:
# WP_BASE_URL=http://127.0.0.1:8888
# WP_ADMIN_USER=admin
# WP_ADMIN_PASS=password

# Used only by scripts/verify-live-truth-safe.mjs for backend truth inspection,
# not read by the Playwright entitlement test itself:
# SUPABASE_URL=https://example.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=replace-in-local-shell-only
